            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Downtown Doner\",\n  \"imageUrl\": \"https://example.com/doner.jpg\",\n  \"food\": [],\n  \"time\": \"09:00-21:00\",\n  \"pickup\": true,\n  \"delivery\": true,\n  \"isOpen\": true,\n  \"location\": {\n    \"id\": \"loc-01\",\n    \"latitude\": 22.5726,\n    \"latitudeDelta\": 0.01,\n    \"longitude\": 88.3639,\n    \"longitudeDelta\": 0.01,\n    \"address\": \"Kolkata\",\n    \"title\": \"Main Branch\"\n  }\n}"
