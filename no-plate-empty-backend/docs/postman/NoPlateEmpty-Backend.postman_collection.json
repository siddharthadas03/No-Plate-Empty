    {
      "name": "02 Admin",
      "item": [
        {
          "name": "Get Pending Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/pending-users"
          }
        },
        {
          "name": "Approve DONOR",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/approve/{{donorUserId}}"
          }
        },
        {
          "name": "Approve NGO",
          "request": {
            "method": "PATCH",
            "header": [
              {
