      "item": [
        {
          "name": "Register SUPER_ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Main Admin\",\n  \"email\": \"admin1@example.com\",\n  \"password\": \"Admin@123\",\n  \"role\": \"SUPER_ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login SUPER_ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
